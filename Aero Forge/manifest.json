{
  "manifest_version": 3,
  "name": "Aero Forge",
  "version": "1.0",
  "description": "Aircraft Concept Design Suite",

  "action": {
    "default_popup": "popup.html"
  },

  "web_accessible_resources": [
    {
      "resources": ["data/**/*.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
